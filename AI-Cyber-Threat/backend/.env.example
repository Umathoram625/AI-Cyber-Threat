# MongoDB Atlas connection string (required - do NOT use localhost)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DATABASE_NAME=cyber_threat_intel

# JWT (required - use a strong random secret in production)
JWT_SECRET=<your_strong_random_secret>
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# API Keys
NEWSDATA_API_KEY=<your_newsdata_api_key>
SERPER_API_KEY=<your_serper_api_key>
OPENAI_API_KEY=<your_openai_api_key>
OPENAI_MODEL=gpt-4o-mini
GOOGLE_CLIENT_ID=<your_google_client_id>

# Admin credentials
ADMIN_EMAIL=admin@cti.local
ADMIN_PASSWORD=AdminPassword123!

# CORS - add your deployed frontend URL
CORS_ORIGINS=["https://your-frontend.onrender.com","http://localhost:5173"]

# Port (Render sets this automatically)
PORT=8000
